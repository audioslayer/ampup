<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Color Palette ─────────────────────────────────────────── -->
    <Color x:Key="BgBase">#0F0F0F</Color>
    <Color x:Key="BgDark">#141414</Color>
    <Color x:Key="CardBg">#1C1C1C</Color>
    <Color x:Key="CardBorder">#2A2A2A</Color>
    <Color x:Key="InputBg">#242424</Color>
    <Color x:Key="InputBorder">#363636</Color>
    <Color x:Key="Accent">#00E676</Color>
    <Color x:Key="AccentGlow">#69F0AE</Color>
    <Color x:Key="AccentDim">#00A854</Color>
    <Color x:Key="TextPrimary">#E8E8E8</Color>
    <Color x:Key="TextSec">#9A9A9A</Color>
    <Color x:Key="TextDim">#555555</Color>
    <Color x:Key="DangerRed">#FF4444</Color>
    <Color x:Key="SuccessGrn">#00DD77</Color>
    <Color x:Key="WarnYellow">#FFB800</Color>

    <!-- ── Brushes ───────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
    <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}" />
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBg}" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorder}" />
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource InputBg}" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorder}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource AccentGlow}" />
    <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource AccentDim}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecBrush" Color="{StaticResource TextSec}" />
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDim}" />
    <SolidColorBrush x:Key="DangerRedBrush" Color="{StaticResource DangerRed}" />
    <SolidColorBrush x:Key="SuccessGrnBrush" Color="{StaticResource SuccessGrn}" />
    <SolidColorBrush x:Key="WarnYellowBrush" Color="{StaticResource WarnYellow}" />

    <!-- ── Card Style ────────────────────────────────────────────── -->
    <Style x:Key="CardPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#00E676" BlurRadius="12" Opacity="0.06" ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Glowing Card (for active/selected elements) ───────────── -->
    <Style x:Key="GlowCardPanel" TargetType="Border" BasedOn="{StaticResource CardPanel}">
        <Setter Property="BorderBrush" Value="{StaticResource AccentDimBrush}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#00E676" BlurRadius="24" Opacity="0.15" ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Label Styles ──────────────────────────────────────────── -->
    <Style x:Key="HeaderText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="SecondaryText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecBrush}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="DimText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- ── Nav Button Style (sidebar hover glow) ───────────────────── -->
    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Width" Value="60" />
        <Setter Property="Height" Value="52" />
        <Setter Property="Margin" Value="8,2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="NavBorder" Background="Transparent" CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="NavBorder" Property="Background" Value="#1A00E676" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ComboBox Hover Border Style ─────────────────────────────── -->
    <Style x:Key="HoverComboBox" TargetType="ComboBox">
        <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource InputBgBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#00E676" BlurRadius="8" Opacity="0.2" ShadowDepth="0" />
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Slider — accent-colored track ───────────────────────────── -->
    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="Height" Value="24" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ── CheckBox ──────────────────────────────────────────────── -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── ToolTip — dark glass ─────────────────────────────────── -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="#FF1A1A1A" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- ── ScrollBar — minimal dark ─────────────────────────────── -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="6" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <!-- ── ScrollViewer ──────────────────────────────────────────── -->
    <Style TargetType="ScrollViewer">
        <Setter Property="PanningMode" Value="Both" />
    </Style>

    <!-- ── Section header with accent left border ───────────────── -->
    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

</ResourceDictionary>
