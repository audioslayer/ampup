<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Color Palette ─────────────────────────────────────────── -->
    <Color x:Key="BgBase">#0F0F0F</Color>
    <Color x:Key="BgDark">#141414</Color>
    <Color x:Key="CardBg">#1C1C1C</Color>
    <Color x:Key="CardBorder">#2A2A2A</Color>
    <Color x:Key="InputBg">#242424</Color>
    <Color x:Key="InputBorder">#363636</Color>
    <Color x:Key="Accent">#00E676</Color>
    <Color x:Key="AccentGlow">#69F0AE</Color>
    <Color x:Key="AccentDim">#00A854</Color>
    <Color x:Key="TextPrimary">#E8E8E8</Color>
    <Color x:Key="TextSec">#9A9A9A</Color>
    <Color x:Key="TextDim">#555555</Color>
    <Color x:Key="DangerRed">#FF4444</Color>
    <Color x:Key="SuccessGrn">#00DD77</Color>
    <Color x:Key="WarnYellow">#FFB800</Color>

    <!-- ── Brushes ───────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
    <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}" />
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBg}" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorder}" />
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource InputBg}" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorder}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource AccentGlow}" />
    <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource AccentDim}" />

    <!-- Alpha-variant accent brushes (updated at runtime by ThemeManager) -->
    <SolidColorBrush x:Key="AccentBorder55Brush" Color="#5500E676" />
    <SolidColorBrush x:Key="AccentBorder22Brush" Color="#2200E676" />
    <SolidColorBrush x:Key="AccentBorder33Brush" Color="#3300E676" />
    <SolidColorBrush x:Key="AccentBorder44Brush" Color="#4400E676" />
    <SolidColorBrush x:Key="AccentHover1ABrush" Color="#1A00E676" />
    <SolidColorBrush x:Key="AccentHover18Brush" Color="#1800E676" />
    <SolidColorBrush x:Key="AccentBg30Brush" Color="#3000E676" />
    <SolidColorBrush x:Key="AccentLabel66Brush" Color="#6600E676" />
    <SolidColorBrush x:Key="AccentLabel77Brush" Color="#7700E676" />
    <SolidColorBrush x:Key="AccentLabel88Brush" Color="#8800E676" />
    <SolidColorBrush x:Key="AccentScroll40Brush" Color="#4000E676" />
    <SolidColorBrush x:Key="AccentScroll70Brush" Color="#7000E676" />
    <SolidColorBrush x:Key="AccentScrollAABrush" Color="#AA00E676" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecBrush" Color="{StaticResource TextSec}" />
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDim}" />
    <SolidColorBrush x:Key="DangerRedBrush" Color="{StaticResource DangerRed}" />
    <SolidColorBrush x:Key="SuccessGrnBrush" Color="{StaticResource SuccessGrn}" />
    <SolidColorBrush x:Key="WarnYellowBrush" Color="{StaticResource WarnYellow}" />

    <!-- ── Card Style ────────────────────────────────────────────── -->
    <Style x:Key="CardPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#00E676" BlurRadius="12" Opacity="0.06" ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Glowing Card (for active/selected elements) ───────────── -->
    <Style x:Key="GlowCardPanel" TargetType="Border" BasedOn="{StaticResource CardPanel}">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentDimBrush}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#00E676" BlurRadius="24" Opacity="0.15" ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Label Styles ──────────────────────────────────────────── -->
    <Style x:Key="HeaderText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="SecondaryText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecBrush}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="DimText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- ── Nav Button Style (sidebar hover glow) ───────────────────── -->
    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Width" Value="62" />
        <Setter Property="Height" Value="56" />
        <Setter Property="Margin" Value="7,2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="NavBorder" Background="Transparent" CornerRadius="10" Padding="0,4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="NavBorder" Property="Background" Value="{DynamicResource AccentHover1ABrush}" />
                            <Setter TargetName="NavBorder" Property="BorderBrush" Value="{DynamicResource AccentBorder22Brush}" />
                            <Setter TargetName="NavBorder" Property="BorderThickness" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ComboBox Hover Border Style ─────────────────────────────── -->
    <Style x:Key="HoverComboBox" TargetType="ComboBox">
        <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource InputBgBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#00E676" BlurRadius="8" Opacity="0.2" ShadowDepth="0" />
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Slider — accent-colored track ───────────────────────────── -->
    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Height" Value="24" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ── CheckBox ──────────────────────────────────────────────── -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Custom check box -->
                        <Border x:Name="CheckBorder"
                                Width="18" Height="18"
                                CornerRadius="4"
                                Background="{DynamicResource InputBgBrush}"
                                BorderBrush="{DynamicResource InputBorderBrush}"
                                BorderThickness="1.5"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0">
                            <!-- Checkmark path -->
                            <Path x:Name="CheckMark"
                                  Data="M 3,8.5 L 7,12.5 L 14,4"
                                  Stroke="{DynamicResource AccentBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Visibility="Collapsed"
                                  Margin="0,-1,0,0" />
                        </Border>
                        <!-- Content -->
                        <ContentPresenter VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="CheckBorder" Property="Background" Value="{DynamicResource AccentHover1ABrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource AccentDimBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ToolTip — dark glass ─────────────────────────────────── -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="#FF1A1A1A" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- ── Slim Green ScrollBar Thumb ──────────────────────────── -->
    <Style x:Key="GreenScrollThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbBorder"
                            Background="{DynamicResource AccentScroll40Brush}"
                            CornerRadius="3"
                            Margin="1" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource AccentScroll70Brush}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource AccentScrollAABrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Vertical ScrollBar ──────────────────────────────────── -->
    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width" Value="8" />
                <Setter Property="Height" Value="Auto" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Border Background="Transparent" CornerRadius="4">
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource GreenScrollThumb}" />
                                    </Track.Thumb>
                                </Track>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="8" />
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Border Background="Transparent" CornerRadius="4">
                                <Track x:Name="PART_Track">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource GreenScrollThumb}" />
                                    </Track.Thumb>
                                </Track>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── ScrollViewer ──────────────────────────────────────────── -->
    <Style TargetType="ScrollViewer">
        <Setter Property="PanningMode" Value="Both" />
    </Style>

    <!-- ── Section header with accent left border ───────────────── -->
    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

</ResourceDictionary>
