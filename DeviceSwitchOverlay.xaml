<Window x:Class="AmpUp.DeviceSwitchOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="RootPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2" />
            <ThicknessAnimation Storyboard.TargetName="RootPanel"
                                Storyboard.TargetProperty="Margin"
                                From="0,20,0,0" To="0,0,0,0" Duration="0:0:0.25">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetName="RootPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3" />
            <ThicknessAnimation Storyboard.TargetName="RootPanel"
                                Storyboard.TargetProperty="Margin"
                                From="0,0,0,0" To="0,12,0,0" Duration="0:0:0.3">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>
    </Window.Resources>

    <!-- Glass panel -->
    <Border x:Name="RootPanel" Opacity="0"
            CornerRadius="12" Padding="20,14"
            MinWidth="280" MaxWidth="400">
        <Border.Background>
            <SolidColorBrush Color="#1C1C1C" Opacity="0.85" />
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#00E676" Opacity="0.3" />
        </Border.BorderBrush>
        <Border.BorderThickness>1</Border.BorderThickness>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="24" Opacity="0.5" ShadowDepth="4" />
        </Border.Effect>

        <StackPanel>
            <!-- Type label -->
            <TextBlock x:Name="TypeLabel" Text="OUTPUT DEVICE"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="#7700E676" Margin="0,0,0,6" />

            <StackPanel Orientation="Horizontal">
                <!-- Speaker/mic icon -->
                <TextBlock x:Name="DeviceIcon" Text="&#x1F50A;" FontSize="22"
                           VerticalAlignment="Center" Margin="0,0,12,0" />

                <!-- Device name -->
                <TextBlock x:Name="DeviceName" Text="Device Name"
                           FontSize="15" FontWeight="Medium"
                           Foreground="#E8E8E8" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" MaxWidth="320" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
