<UserControl x:Class="AmpUp.Views.MixerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:AmpUp.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel Margin="0,0,0,24">

            <!-- ── CHANNEL STRIPS ─────────────────────────────────── -->
            <Grid x:Name="ChannelGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Channel 1 -->
                <Border x:Name="Ch0Border" Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,4,0" Padding="10,12">
                    <StackPanel x:Name="Ch0Panel" />
                </Border>

                <!-- Channel 2 -->
                <Border x:Name="Ch1Border" Grid.Column="1" Style="{StaticResource CardPanel}" Margin="4,0" Padding="10,12">
                    <StackPanel x:Name="Ch1Panel" />
                </Border>

                <!-- Channel 3 -->
                <Border x:Name="Ch2Border" Grid.Column="2" Style="{StaticResource CardPanel}" Margin="4,0" Padding="10,12">
                    <StackPanel x:Name="Ch2Panel" />
                </Border>

                <!-- Channel 4 -->
                <Border x:Name="Ch3Border" Grid.Column="3" Style="{StaticResource CardPanel}" Margin="4,0" Padding="10,12">
                    <StackPanel x:Name="Ch3Panel" />
                </Border>

                <!-- Channel 5 -->
                <Border x:Name="Ch4Border" Grid.Column="4" Style="{StaticResource CardPanel}" Margin="4,0,0,0" Padding="10,12">
                    <StackPanel x:Name="Ch4Panel" />
                </Border>
            </Grid>

            <!-- ── SMART MIX ──────────────────────────────────────── -->
            <Border x:Name="SmartMixSection" Margin="0,12,0,0">
                <StackPanel>

                    <!-- Collapsible header -->
                    <Border x:Name="SmartMixHeader" Cursor="Hand"
                            Background="Transparent"
                            Padding="0,0,0,0"
                            MouseLeftButtonDown="SmartMixHeader_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                            <TextBlock Text="SMART MIX" Style="{StaticResource HeaderText}" Margin="0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="SmartMixArrow" Text="▶" FontSize="9"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Collapsible content -->
                    <StackPanel x:Name="SmartMixContent" Visibility="Collapsed" Margin="0,12,0,0">

                        <!-- AUTO-DUCKING card -->
                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                                    <TextBlock Text="AUTO-DUCKING" Style="{StaticResource HeaderText}" Margin="0" />
                                </StackPanel>
                                <TextBlock Text="Automatically lower other apps when a trigger app (e.g. Discord) is speaking."
                                           Style="{StaticResource SecondaryText}" Margin="0,0,0,12" TextWrapping="Wrap" />
                                <CheckBox x:Name="ChkDuckingEnabled"
                                          Content="Enable auto-ducking"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          Margin="0,0,0,14"
                                          ToolTip="Automatically lower other apps when trigger app is speaking" />

                                <Border BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0"
                                        Padding="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Rule" Style="{StaticResource BodyText}" FontWeight="SemiBold" Margin="0,0,0,10" />
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <StackPanel Margin="0,0,16,0">
                                                <TextBlock Text="Trigger App" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"
                                                           ToolTip="App that triggers volume reduction when active (e.g. discord)" />
                                                <ui:TextBox x:Name="TxtDuckTriggerApp" Width="160"
                                                            PlaceholderText="discord"
                                                            Background="{StaticResource InputBgBrush}"
                                                            BorderBrush="{StaticResource InputBorderBrush}"
                                                            Foreground="{StaticResource TextPrimaryBrush}"
                                                            ToolTip="App that triggers volume reduction when active (e.g. discord)" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Target Apps (blank = all)" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"
                                                           ToolTip="Apps to duck — leave blank to duck everything" />
                                                <ui:TextBox x:Name="TxtDuckTargetApps" Width="220"
                                                            PlaceholderText="spotify, chrome, … (comma-separated)"
                                                            Background="{StaticResource InputBgBrush}"
                                                            BorderBrush="{StaticResource InputBorderBrush}"
                                                            Foreground="{StaticResource TextPrimaryBrush}"
                                                            ToolTip="Apps to duck — leave blank to duck everything" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel Margin="0,0,16,0">
                                                <TextBlock Text="Duck Amount %" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"
                                                           ToolTip="How much to reduce volume — 100% = fully muted" />
                                                <Slider x:Name="SldDuckPercent"
                                                        Minimum="0" Maximum="100" Value="50"
                                                        Width="160" TickFrequency="10" IsSnapToTickEnabled="True"
                                                        ToolTip="How much to reduce volume — 100% = fully muted" />
                                                <TextBlock x:Name="TxtDuckPercentLabel"
                                                           Text="50%" Style="{StaticResource SecondaryText}"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,0">
                                                <TextBlock Text="Fade Out (ms)" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"
                                                           ToolTip="Time to fade volume down when trigger starts (ms)" />
                                                <ui:TextBox x:Name="TxtDuckFadeOut" Width="80"
                                                            PlaceholderText="200"
                                                            Background="{StaticResource InputBgBrush}"
                                                            BorderBrush="{StaticResource InputBorderBrush}"
                                                            Foreground="{StaticResource TextPrimaryBrush}"
                                                            ToolTip="Time to fade volume down when trigger starts (ms)" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Fade In (ms)" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"
                                                           ToolTip="Time to restore volume after trigger stops (ms)" />
                                                <ui:TextBox x:Name="TxtDuckFadeIn" Width="80"
                                                            PlaceholderText="500"
                                                            Background="{StaticResource InputBgBrush}"
                                                            BorderBrush="{StaticResource InputBorderBrush}"
                                                            Foreground="{StaticResource TextPrimaryBrush}"
                                                            ToolTip="Time to restore volume after trigger stops (ms)" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- AUTO-PROFILE SWITCHING card -->
                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                                    <TextBlock Text="AUTO-PROFILE SWITCHING" Style="{StaticResource HeaderText}" Margin="0" />
                                </StackPanel>
                                <TextBlock Text="Switch profiles automatically based on the focused app."
                                           Style="{StaticResource SecondaryText}" Margin="0,0,0,12" TextWrapping="Wrap" />
                                <CheckBox x:Name="ChkAutoSwitchEnabled"
                                          Content="Enable auto-profile switching"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          Margin="0,0,0,6"
                                          ToolTip="Switch profiles automatically based on the focused app" />
                                <CheckBox x:Name="ChkAutoSwitchRevert"
                                          Content="Revert to default profile when no rule matches"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          Margin="0,0,0,14"
                                          ToolTip="Go back to Default profile when no rule matches the focused app" />

                                <Border BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0"
                                        Padding="0,12,0,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="App Name" Style="{StaticResource SecondaryText}" Width="180" Margin="0,0,8,0"
                                                       ToolTip="When this app is in the foreground, switch to the profile" />
                                            <TextBlock Text="Profile" Style="{StaticResource SecondaryText}" Width="180"
                                                       ToolTip="Profile to activate when the app is focused" />
                                        </StackPanel>
                                        <!-- Row 0 -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <ui:TextBox x:Name="TxtAutoRule0App" Width="175" Margin="0,0,8,0"
                                                        PlaceholderText="app.exe"
                                                        Background="{StaticResource InputBgBrush}"
                                                        BorderBrush="{StaticResource InputBorderBrush}"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        ToolTip="When this app is in the foreground, switch to the profile" />
                                            <ComboBox x:Name="CmbAutoRule0Profile" Width="175"
                                                      Background="{StaticResource InputBgBrush}"
                                                      BorderBrush="{StaticResource InputBorderBrush}"
                                                      Foreground="{StaticResource TextPrimaryBrush}"
                                                      ToolTip="Profile to activate when the app is focused" />
                                        </StackPanel>
                                        <!-- Row 1 -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <ui:TextBox x:Name="TxtAutoRule1App" Width="175" Margin="0,0,8,0"
                                                        PlaceholderText="app.exe"
                                                        Background="{StaticResource InputBgBrush}"
                                                        BorderBrush="{StaticResource InputBorderBrush}"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        ToolTip="When this app is in the foreground, switch to the profile" />
                                            <ComboBox x:Name="CmbAutoRule1Profile" Width="175"
                                                      Background="{StaticResource InputBgBrush}"
                                                      BorderBrush="{StaticResource InputBorderBrush}"
                                                      Foreground="{StaticResource TextPrimaryBrush}"
                                                      ToolTip="Profile to activate when the app is focused" />
                                        </StackPanel>
                                        <!-- Row 2 -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <ui:TextBox x:Name="TxtAutoRule2App" Width="175" Margin="0,0,8,0"
                                                        PlaceholderText="app.exe"
                                                        Background="{StaticResource InputBgBrush}"
                                                        BorderBrush="{StaticResource InputBorderBrush}"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        ToolTip="When this app is in the foreground, switch to the profile" />
                                            <ComboBox x:Name="CmbAutoRule2Profile" Width="175"
                                                      Background="{StaticResource InputBgBrush}"
                                                      BorderBrush="{StaticResource InputBorderBrush}"
                                                      Foreground="{StaticResource TextPrimaryBrush}"
                                                      ToolTip="Profile to activate when the app is focused" />
                                        </StackPanel>
                                        <!-- Row 3 -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <ui:TextBox x:Name="TxtAutoRule3App" Width="175" Margin="0,0,8,0"
                                                        PlaceholderText="app.exe"
                                                        Background="{StaticResource InputBgBrush}"
                                                        BorderBrush="{StaticResource InputBorderBrush}"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        ToolTip="When this app is in the foreground, switch to the profile" />
                                            <ComboBox x:Name="CmbAutoRule3Profile" Width="175"
                                                      Background="{StaticResource InputBgBrush}"
                                                      BorderBrush="{StaticResource InputBorderBrush}"
                                                      Foreground="{StaticResource TextPrimaryBrush}"
                                                      ToolTip="Profile to activate when the app is focused" />
                                        </StackPanel>
                                        <!-- Row 4 -->
                                        <StackPanel Orientation="Horizontal">
                                            <ui:TextBox x:Name="TxtAutoRule4App" Width="175" Margin="0,0,8,0"
                                                        PlaceholderText="app.exe"
                                                        Background="{StaticResource InputBgBrush}"
                                                        BorderBrush="{StaticResource InputBorderBrush}"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        ToolTip="When this app is in the foreground, switch to the profile" />
                                            <ComboBox x:Name="CmbAutoRule4Profile" Width="175"
                                                      Background="{StaticResource InputBgBrush}"
                                                      BorderBrush="{StaticResource InputBorderBrush}"
                                                      Foreground="{StaticResource TextPrimaryBrush}"
                                                      ToolTip="Profile to activate when the app is focused" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
