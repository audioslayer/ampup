<UserControl x:Class="AmpUp.Views.MixerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:AmpUp.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel Margin="0,0,0,24">
            <Border x:Name="MixerSurfaceBar" Style="{StaticResource CardPanel}" Margin="0,0,0,10" Visibility="Collapsed">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="MIXER SURFACE" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>
                    <controls:SegmentedControl x:Name="MixerDeviceSelector"
                                               HorizontalAlignment="Left"
                                               MinWidth="360" />
                </StackPanel>
            </Border>

            <StackPanel x:Name="TurnUpMixerContent">

            <!-- ── CHANNEL STRIPS + SETTINGS GRID ─────────────────── -->
            <!-- 4 rows: knob dials, TARGET, CURVE, VOLUME RANGE — rows auto-size
                 to tallest cell so cards align across all 5 columns. -->
            <Grid x:Name="ChannelGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 0: Channel strip cards -->
                <Border x:Name="Ch0Border" Grid.Row="0" Grid.Column="0" Style="{StaticResource CardPanel}" Padding="0" ClipToBounds="True" Margin="0,0,4,10">
                    <Grid><controls:ChannelGlowControl x:Name="Ch0Glow" /><StackPanel x:Name="Ch0Panel" Margin="10,12" /></Grid>
                </Border>
                <Border x:Name="Ch1Border" Grid.Row="0" Grid.Column="1" Style="{StaticResource CardPanel}" Padding="0" ClipToBounds="True" Margin="4,0,4,10">
                    <Grid><controls:ChannelGlowControl x:Name="Ch1Glow" /><StackPanel x:Name="Ch1Panel" Margin="10,12" /></Grid>
                </Border>
                <Border x:Name="Ch2Border" Grid.Row="0" Grid.Column="2" Style="{StaticResource CardPanel}" Padding="0" ClipToBounds="True" Margin="4,0,4,10">
                    <Grid><controls:ChannelGlowControl x:Name="Ch2Glow" /><StackPanel x:Name="Ch2Panel" Margin="10,12" /></Grid>
                </Border>
                <Border x:Name="Ch3Border" Grid.Row="0" Grid.Column="3" Style="{StaticResource CardPanel}" Padding="0" ClipToBounds="True" Margin="4,0,4,10">
                    <Grid><controls:ChannelGlowControl x:Name="Ch3Glow" /><StackPanel x:Name="Ch3Panel" Margin="10,12" /></Grid>
                </Border>
                <Border x:Name="Ch4Border" Grid.Row="0" Grid.Column="4" Style="{StaticResource CardPanel}" Padding="0" ClipToBounds="True" Margin="4,0,0,10">
                    <Grid><controls:ChannelGlowControl x:Name="Ch4Glow" /><StackPanel x:Name="Ch4Panel" Margin="10,12" /></Grid>
                </Border>

                <!-- Rows 1-3: VOLUME RANGE / TARGET / CURVE — placed by code-behind -->
                <Border x:Name="Ch0Range" Grid.Row="1" Grid.Column="0" Margin="0,0,4,0" />
                <Border x:Name="Ch1Range" Grid.Row="1" Grid.Column="1" Margin="4,0" />
                <Border x:Name="Ch2Range" Grid.Row="1" Grid.Column="2" Margin="4,0" />
                <Border x:Name="Ch3Range" Grid.Row="1" Grid.Column="3" Margin="4,0" />
                <Border x:Name="Ch4Range" Grid.Row="1" Grid.Column="4" Margin="4,0,0,0" />

                <Border x:Name="Ch0Target" Grid.Row="2" Grid.Column="0" Margin="0,0,4,0" />
                <Border x:Name="Ch1Target" Grid.Row="2" Grid.Column="1" Margin="4,0" />
                <Border x:Name="Ch2Target" Grid.Row="2" Grid.Column="2" Margin="4,0" />
                <Border x:Name="Ch3Target" Grid.Row="2" Grid.Column="3" Margin="4,0" />
                <Border x:Name="Ch4Target" Grid.Row="2" Grid.Column="4" Margin="4,0,0,0" />

                <Border x:Name="Ch0Curve" Grid.Row="3" Grid.Column="0" Margin="0,0,4,0" />
                <Border x:Name="Ch1Curve" Grid.Row="3" Grid.Column="1" Margin="4,0" />
                <Border x:Name="Ch2Curve" Grid.Row="3" Grid.Column="2" Margin="4,0" />
                <Border x:Name="Ch3Curve" Grid.Row="3" Grid.Column="3" Margin="4,0" />
                <Border x:Name="Ch4Curve" Grid.Row="3" Grid.Column="4" Margin="4,0,0,0" />
            </Grid>

            <!-- ── SMART MIX ──────────────────────────────────────── -->
            <Border x:Name="SmartMixSection" Style="{StaticResource CardPanel}" Margin="0,10,0,0">
                <StackPanel>
                    <Border x:Name="SmartMixHeader" Cursor="Hand"
                            Background="Transparent" Padding="0,0,0,0"
                            MouseLeftButtonDown="SmartMixHeader_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                            <TextBlock Text="SMART MIX" Style="{StaticResource HeaderText}" Margin="0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="SmartMixArrow" Text="▶" FontSize="9"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>
                    <StackPanel x:Name="SmartMixContent" Visibility="Collapsed" Margin="0,12,0,0" />
                </StackPanel>
            </Border>

            <!-- ── AUDIO SESSIONS (collapsible) ──────────────────── -->
            <Border x:Name="AudioSessionsSection" Style="{StaticResource CardPanel}" Margin="0,10,0,0">
                <StackPanel>
                    <Border x:Name="AudioSessionsHeader" Cursor="Hand"
                            Background="Transparent" Padding="0,0,0,0"
                            MouseLeftButtonDown="AudioSessionsHeader_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                            <TextBlock Text="AUDIO SESSIONS" Style="{StaticResource HeaderText}" Margin="0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="AudioSessionsArrow" Text="▶" FontSize="9"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>
                    <StackPanel x:Name="AudioSessionsContent" Visibility="Collapsed" Margin="0,12,0,0" />
                </StackPanel>
            </Border>
            </StackPanel>

            <Border x:Name="StreamControllerMixerPanel" Style="{StaticResource CardPanel}" Margin="0,10,0,0" Visibility="Collapsed">
                <StackPanel x:Name="StreamControllerMixerContent" />
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
