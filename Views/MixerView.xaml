<UserControl x:Class="AmpUp.Views.MixerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:AmpUp.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel Margin="0,0,0,24">

            <!-- ── CHANNEL STRIPS ─────────────────────────────────── -->
            <Grid x:Name="ChannelGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Channel 1 -->
                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                    <Border x:Name="Ch0Border" Style="{StaticResource CardPanel}" Padding="0" ClipToBounds="True" Margin="0,0,0,10">
                        <Grid>
                            <controls:ChannelGlowControl x:Name="Ch0Glow" />
                            <StackPanel x:Name="Ch0Panel" Margin="10,12" />
                        </Grid>
                    </Border>
                    <StackPanel x:Name="Ch0Settings" />
                </StackPanel>

                <!-- Channel 2 -->
                <StackPanel Grid.Column="1" Margin="4,0">
                    <Border x:Name="Ch1Border" Style="{StaticResource CardPanel}" Padding="0" ClipToBounds="True" Margin="0,0,0,10">
                        <Grid>
                            <controls:ChannelGlowControl x:Name="Ch1Glow" />
                            <StackPanel x:Name="Ch1Panel" Margin="10,12" />
                        </Grid>
                    </Border>
                    <StackPanel x:Name="Ch1Settings" />
                </StackPanel>

                <!-- Channel 3 -->
                <StackPanel Grid.Column="2" Margin="4,0">
                    <Border x:Name="Ch2Border" Style="{StaticResource CardPanel}" Padding="0" ClipToBounds="True" Margin="0,0,0,10">
                        <Grid>
                            <controls:ChannelGlowControl x:Name="Ch2Glow" />
                            <StackPanel x:Name="Ch2Panel" Margin="10,12" />
                        </Grid>
                    </Border>
                    <StackPanel x:Name="Ch2Settings" />
                </StackPanel>

                <!-- Channel 4 -->
                <StackPanel Grid.Column="3" Margin="4,0">
                    <Border x:Name="Ch3Border" Style="{StaticResource CardPanel}" Padding="0" ClipToBounds="True" Margin="0,0,0,10">
                        <Grid>
                            <controls:ChannelGlowControl x:Name="Ch3Glow" />
                            <StackPanel x:Name="Ch3Panel" Margin="10,12" />
                        </Grid>
                    </Border>
                    <StackPanel x:Name="Ch3Settings" />
                </StackPanel>

                <!-- Channel 5 -->
                <StackPanel Grid.Column="4" Margin="4,0,0,0">
                    <Border x:Name="Ch4Border" Style="{StaticResource CardPanel}" Padding="0" ClipToBounds="True" Margin="0,0,0,10">
                        <Grid>
                            <controls:ChannelGlowControl x:Name="Ch4Glow" />
                            <StackPanel x:Name="Ch4Panel" Margin="10,12" />
                        </Grid>
                    </Border>
                    <StackPanel x:Name="Ch4Settings" />
                </StackPanel>
            </Grid>

            <!-- ── SMART MIX ──────────────────────────────────────── -->
            <Border x:Name="SmartMixSection" Style="{StaticResource CardPanel}" Margin="0,10,0,0">
                <StackPanel>
                    <Border x:Name="SmartMixHeader" Cursor="Hand"
                            Background="Transparent" Padding="0,0,0,0"
                            MouseLeftButtonDown="SmartMixHeader_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                            <TextBlock Text="SMART MIX" Style="{StaticResource HeaderText}" Margin="0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="SmartMixArrow" Text="▶" FontSize="9"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>
                    <StackPanel x:Name="SmartMixContent" Visibility="Collapsed" Margin="0,12,0,0" />
                </StackPanel>
            </Border>

            <!-- ── AUDIO SESSIONS (collapsible) ──────────────────── -->
            <Border x:Name="AudioSessionsSection" Style="{StaticResource CardPanel}" Margin="0,10,0,0">
                <StackPanel>
                    <Border x:Name="AudioSessionsHeader" Cursor="Hand"
                            Background="Transparent" Padding="0,0,0,0"
                            MouseLeftButtonDown="AudioSessionsHeader_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                            <TextBlock Text="AUDIO SESSIONS" Style="{StaticResource HeaderText}" Margin="0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="AudioSessionsArrow" Text="▶" FontSize="9"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>
                    <StackPanel x:Name="AudioSessionsContent" Visibility="Collapsed" Margin="0,12,0,0" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
