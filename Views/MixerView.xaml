<UserControl x:Class="AmpUp.Views.MixerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:AmpUp.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel Margin="0,0,0,24">

            <!-- ── CHANNEL STRIPS ─────────────────────────────────── -->
            <Grid x:Name="ChannelGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Channel 1 -->
                <Border x:Name="Ch0Border" Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,4,0" Padding="10,12">
                    <StackPanel x:Name="Ch0Panel" />
                </Border>

                <!-- Channel 2 -->
                <Border x:Name="Ch1Border" Grid.Column="1" Style="{StaticResource CardPanel}" Margin="4,0" Padding="10,12">
                    <StackPanel x:Name="Ch1Panel" />
                </Border>

                <!-- Channel 3 -->
                <Border x:Name="Ch2Border" Grid.Column="2" Style="{StaticResource CardPanel}" Margin="4,0" Padding="10,12">
                    <StackPanel x:Name="Ch2Panel" />
                </Border>

                <!-- Channel 4 -->
                <Border x:Name="Ch3Border" Grid.Column="3" Style="{StaticResource CardPanel}" Margin="4,0" Padding="10,12">
                    <StackPanel x:Name="Ch3Panel" />
                </Border>

                <!-- Channel 5 -->
                <Border x:Name="Ch4Border" Grid.Column="4" Style="{StaticResource CardPanel}" Margin="4,0,0,0" Padding="10,12">
                    <StackPanel x:Name="Ch4Panel" />
                </Border>
            </Grid>

            <!-- ── SMART MIX ──────────────────────────────────────── -->
            <Border x:Name="SmartMixSection" Margin="0,12,0,0">
                <StackPanel>

                    <!-- Collapsible header -->
                    <Border x:Name="SmartMixHeader" Cursor="Hand"
                            Background="Transparent"
                            Padding="0,0,0,0"
                            MouseLeftButtonDown="SmartMixHeader_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                            <TextBlock Text="SMART MIX" Style="{StaticResource HeaderText}" Margin="0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="SmartMixArrow" Text="▶" FontSize="9"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Collapsible content (built dynamically in code-behind) -->
                    <StackPanel x:Name="SmartMixContent" Visibility="Collapsed" Margin="0,12,0,0" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
