<UserControl x:Class="AmpUp.Views.MixerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:AmpUp.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel Margin="0,0,0,24">

            <!-- ── CHANNEL STRIPS ─────────────────────────────────── -->
            <Grid x:Name="ChannelGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Channel 1 -->
                <Border x:Name="Ch0Border" Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,4,0" Padding="10,12">
                    <StackPanel x:Name="Ch0Panel" />
                </Border>

                <!-- Channel 2 -->
                <Border x:Name="Ch1Border" Grid.Column="1" Style="{StaticResource CardPanel}" Margin="4,0" Padding="10,12">
                    <StackPanel x:Name="Ch1Panel" />
                </Border>

                <!-- Channel 3 -->
                <Border x:Name="Ch2Border" Grid.Column="2" Style="{StaticResource CardPanel}" Margin="4,0" Padding="10,12">
                    <StackPanel x:Name="Ch2Panel" />
                </Border>

                <!-- Channel 4 -->
                <Border x:Name="Ch3Border" Grid.Column="3" Style="{StaticResource CardPanel}" Margin="4,0" Padding="10,12">
                    <StackPanel x:Name="Ch3Panel" />
                </Border>

                <!-- Channel 5 -->
                <Border x:Name="Ch4Border" Grid.Column="4" Style="{StaticResource CardPanel}" Margin="4,0,0,0" Padding="10,12">
                    <StackPanel x:Name="Ch4Panel" />
                </Border>
            </Grid>

            <!-- ── SMART MIX ──────────────────────────────────────── -->
            <Border x:Name="SmartMixSection" Margin="0,12,0,0">
                <StackPanel>

                    <!-- Collapsible header -->
                    <Border x:Name="SmartMixHeader" Cursor="Hand"
                            Background="Transparent"
                            Padding="0,0,0,0"
                            MouseLeftButtonDown="SmartMixHeader_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                            <TextBlock Text="SMART MIX" Style="{StaticResource HeaderText}" Margin="0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="SmartMixArrow" Text="▶" FontSize="9"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Collapsible content -->
                    <StackPanel x:Name="SmartMixContent" Visibility="Collapsed" Margin="0,12,0,0">

                        <!-- ── AUTO-DUCKING card ────────────────────────── -->
                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                            <StackPanel>

                                <!-- Card header row: icon + title + enable toggle -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="3" CornerRadius="2"
                                            Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                                    <TextBlock Grid.Column="1" Text="🔉  AUTO-DUCKING"
                                               Style="{StaticResource HeaderText}" Margin="0"
                                               VerticalAlignment="Center" />
                                    <CheckBox x:Name="ChkDuckingEnabled"
                                              Grid.Column="3"
                                              VerticalAlignment="Center"
                                              ToolTip="Automatically lower other apps when trigger app is speaking" />
                                </Grid>

                                <!-- Ducking rule content (visually disabled when unchecked via IsEnabled binding) -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, ElementName=ChkDuckingEnabled}" Value="False">
                                                    <Setter Property="Opacity" Value="0.4" />
                                                    <Setter Property="IsEnabled" Value="False" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <!-- Flow: trigger → target -->
                                    <TextBlock Text="When this app is active..."
                                               Style="{StaticResource SecondaryText}" Margin="0,0,0,6" />
                                    <ui:TextBox x:Name="TxtDuckTriggerApp"
                                                PlaceholderText="discord"
                                                Background="{StaticResource InputBgBrush}"
                                                BorderBrush="{StaticResource InputBorderBrush}"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Margin="0,0,0,12"
                                                ToolTip="App that triggers volume reduction when active (e.g. discord)" />

                                    <TextBlock Text="...lower these apps (blank = all)"
                                               Style="{StaticResource SecondaryText}" Margin="0,0,0,6" />
                                    <ui:TextBox x:Name="TxtDuckTargetApps"
                                                PlaceholderText="spotify, chrome, … (comma-separated)"
                                                Background="{StaticResource InputBgBrush}"
                                                BorderBrush="{StaticResource InputBorderBrush}"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Margin="0,0,0,16"
                                                ToolTip="Apps to duck — leave blank to duck everything" />

                                    <!-- Duck amount slider -->
                                    <Border Background="#181818" CornerRadius="8" Padding="14,12" Margin="0,0,0,14">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="How much to lower?"
                                                           Style="{StaticResource SecondaryText}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock x:Name="TxtDuckPercentLabel"
                                                           Grid.Column="1"
                                                           Text="50%"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                            <Slider x:Name="SldDuckPercent"
                                                    Minimum="0" Maximum="100" Value="50"
                                                    TickFrequency="10" IsSnapToTickEnabled="True"
                                                    ToolTip="How much to reduce volume — 100% = fully muted" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Fade timings: compact inline row -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Fade Out -->
                                        <Border Grid.Column="0" Background="#181818" CornerRadius="8" Padding="14,10">
                                            <StackPanel>
                                                <TextBlock Text="⚡  Fade Out"
                                                           Style="{StaticResource SecondaryText}" Margin="0,0,0,6" />
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBox x:Name="TxtDuckFadeOut"
                                                                Grid.Column="0"
                                                                PlaceholderText="200"
                                                                Background="{StaticResource InputBgBrush}"
                                                                BorderBrush="{StaticResource InputBorderBrush}"
                                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                                ToolTip="Time to fade volume down when trigger starts (ms)" />
                                                    <TextBlock Grid.Column="1" Text="ms"
                                                               Style="{StaticResource SecondaryText}"
                                                               VerticalAlignment="Center" Margin="6,0,0,0" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Fade In -->
                                        <Border Grid.Column="2" Background="#181818" CornerRadius="8" Padding="14,10">
                                            <StackPanel>
                                                <TextBlock Text="↗  Fade In"
                                                           Style="{StaticResource SecondaryText}" Margin="0,0,0,6" />
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBox x:Name="TxtDuckFadeIn"
                                                                Grid.Column="0"
                                                                PlaceholderText="500"
                                                                Background="{StaticResource InputBgBrush}"
                                                                BorderBrush="{StaticResource InputBorderBrush}"
                                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                                ToolTip="Time to restore volume after trigger stops (ms)" />
                                                    <TextBlock Grid.Column="1" Text="ms"
                                                               Style="{StaticResource SecondaryText}"
                                                               VerticalAlignment="Center" Margin="6,0,0,0" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── AUTO-PROFILE SWITCHING card ─────────────── -->
                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,0">
                            <StackPanel>

                                <!-- Card header row: icon + title + enable toggle -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="3" CornerRadius="2"
                                            Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                                    <TextBlock Grid.Column="1" Text="🔄  AUTO-PROFILE SWITCHING"
                                               Style="{StaticResource HeaderText}" Margin="0"
                                               VerticalAlignment="Center" />
                                    <CheckBox x:Name="ChkAutoSwitchEnabled"
                                              Grid.Column="3"
                                              VerticalAlignment="Center"
                                              ToolTip="Switch profiles automatically based on the focused app" />
                                </Grid>

                                <!-- Revert checkbox -->
                                <CheckBox x:Name="ChkAutoSwitchRevert"
                                          Content="Revert to default when no rule matches"
                                          Foreground="{StaticResource TextSecBrush}"
                                          FontSize="12"
                                          Margin="0,0,0,16"
                                          ToolTip="Go back to Default profile when no rule matches the focused app" />

                                <!-- Rule cards (visually disabled when unchecked) -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, ElementName=ChkAutoSwitchEnabled}" Value="False">
                                                    <Setter Property="Opacity" Value="0.4" />
                                                    <Setter Property="IsEnabled" Value="False" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <!-- Rule 0 -->
                                    <Border Background="#1E1E1E" CornerRadius="8" Padding="12,10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ui:TextBox x:Name="TxtAutoRule0App" Grid.Column="0"
                                                        PlaceholderText="app.exe"
                                                        Background="{StaticResource InputBgBrush}"
                                                        BorderBrush="{StaticResource InputBorderBrush}"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        ToolTip="When this app is in the foreground, switch to the profile" />
                                            <TextBlock Grid.Column="1" Text="→"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       FontSize="16" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" Margin="10,0" />
                                            <controls:ListPicker x:Name="CmbAutoRule0Profile" Grid.Column="2"
                                                      ToolTip="Profile to activate when the app is focused" />
                                        </Grid>
                                    </Border>

                                    <!-- Rule 1 -->
                                    <Border Background="#1E1E1E" CornerRadius="8" Padding="12,10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ui:TextBox x:Name="TxtAutoRule1App" Grid.Column="0"
                                                        PlaceholderText="app.exe"
                                                        Background="{StaticResource InputBgBrush}"
                                                        BorderBrush="{StaticResource InputBorderBrush}"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        ToolTip="When this app is in the foreground, switch to the profile" />
                                            <TextBlock Grid.Column="1" Text="→"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       FontSize="16" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" Margin="10,0" />
                                            <controls:ListPicker x:Name="CmbAutoRule1Profile" Grid.Column="2"
                                                      ToolTip="Profile to activate when the app is focused" />
                                        </Grid>
                                    </Border>

                                    <!-- Rule 2 -->
                                    <Border Background="#1E1E1E" CornerRadius="8" Padding="12,10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ui:TextBox x:Name="TxtAutoRule2App" Grid.Column="0"
                                                        PlaceholderText="app.exe"
                                                        Background="{StaticResource InputBgBrush}"
                                                        BorderBrush="{StaticResource InputBorderBrush}"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        ToolTip="When this app is in the foreground, switch to the profile" />
                                            <TextBlock Grid.Column="1" Text="→"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       FontSize="16" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" Margin="10,0" />
                                            <controls:ListPicker x:Name="CmbAutoRule2Profile" Grid.Column="2"
                                                      ToolTip="Profile to activate when the app is focused" />
                                        </Grid>
                                    </Border>

                                    <!-- Rule 3 -->
                                    <Border Background="#1E1E1E" CornerRadius="8" Padding="12,10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ui:TextBox x:Name="TxtAutoRule3App" Grid.Column="0"
                                                        PlaceholderText="app.exe"
                                                        Background="{StaticResource InputBgBrush}"
                                                        BorderBrush="{StaticResource InputBorderBrush}"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        ToolTip="When this app is in the foreground, switch to the profile" />
                                            <TextBlock Grid.Column="1" Text="→"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       FontSize="16" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" Margin="10,0" />
                                            <controls:ListPicker x:Name="CmbAutoRule3Profile" Grid.Column="2"
                                                      ToolTip="Profile to activate when the app is focused" />
                                        </Grid>
                                    </Border>

                                    <!-- Rule 4 -->
                                    <Border Background="#1E1E1E" CornerRadius="8" Padding="12,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ui:TextBox x:Name="TxtAutoRule4App" Grid.Column="0"
                                                        PlaceholderText="app.exe"
                                                        Background="{StaticResource InputBgBrush}"
                                                        BorderBrush="{StaticResource InputBorderBrush}"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        ToolTip="When this app is in the foreground, switch to the profile" />
                                            <TextBlock Grid.Column="1" Text="→"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       FontSize="16" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" Margin="10,0" />
                                            <controls:ListPicker x:Name="CmbAutoRule4Profile" Grid.Column="2"
                                                      ToolTip="Profile to activate when the app is focused" />
                                        </Grid>
                                    </Border>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
