<UserControl x:Class="AmpUp.Views.MixerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:AmpUp.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel Margin="0,0,0,24">

            <Border Margin="0,0,0,14" Padding="18,16,18,14" CornerRadius="14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#22151515" Offset="0" />
                        <GradientStop Color="#181C1C1C" Offset="0.65" />
                        <GradientStop Color="#10202020" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4400E676" Offset="0" />
                        <GradientStop Color="#222A2A2A" Offset="0.6" />
                        <GradientStop Color="#102A2A2A" Offset="1" />
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Mixer Dashboard"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="Live control surface for your five hardware channels. Tune routing, curves, and ranges without losing the at-a-glance mixer feel."
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   MaxWidth="860"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecBrush}" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            CornerRadius="12"
                            Padding="12,8"
                            Background="#1800E676"
                            BorderBrush="#4400E676"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="MAIN VIEW"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}" />
                            <TextBlock Text="Five channels. Live meters. Fast editing."
                                       Margin="0,3,0,0"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid x:Name="ChannelGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="Ch0Border" Grid.Row="0" Grid.Column="0" Style="{StaticResource CardPanel}" Padding="0" ClipToBounds="True" Margin="0,0,4,12">
                    <Grid><controls:ChannelGlowControl x:Name="Ch0Glow" /><StackPanel x:Name="Ch0Panel" Margin="14,14,14,12" /></Grid>
                </Border>
                <Border x:Name="Ch1Border" Grid.Row="0" Grid.Column="1" Style="{StaticResource CardPanel}" Padding="0" ClipToBounds="True" Margin="4,0,4,12">
                    <Grid><controls:ChannelGlowControl x:Name="Ch1Glow" /><StackPanel x:Name="Ch1Panel" Margin="14,14,14,12" /></Grid>
                </Border>
                <Border x:Name="Ch2Border" Grid.Row="0" Grid.Column="2" Style="{StaticResource CardPanel}" Padding="0" ClipToBounds="True" Margin="4,0,4,12">
                    <Grid><controls:ChannelGlowControl x:Name="Ch2Glow" /><StackPanel x:Name="Ch2Panel" Margin="14,14,14,12" /></Grid>
                </Border>
                <Border x:Name="Ch3Border" Grid.Row="0" Grid.Column="3" Style="{StaticResource CardPanel}" Padding="0" ClipToBounds="True" Margin="4,0,4,12">
                    <Grid><controls:ChannelGlowControl x:Name="Ch3Glow" /><StackPanel x:Name="Ch3Panel" Margin="14,14,14,12" /></Grid>
                </Border>
                <Border x:Name="Ch4Border" Grid.Row="0" Grid.Column="4" Style="{StaticResource CardPanel}" Padding="0" ClipToBounds="True" Margin="4,0,0,12">
                    <Grid><controls:ChannelGlowControl x:Name="Ch4Glow" /><StackPanel x:Name="Ch4Panel" Margin="14,14,14,12" /></Grid>
                </Border>

                <Border x:Name="Ch0Settings" Grid.Row="1" Grid.Column="0" Margin="0,0,4,0" />
                <Border x:Name="Ch1Settings" Grid.Row="1" Grid.Column="1" Margin="4,0" />
                <Border x:Name="Ch2Settings" Grid.Row="1" Grid.Column="2" Margin="4,0" />
                <Border x:Name="Ch3Settings" Grid.Row="1" Grid.Column="3" Margin="4,0" />
                <Border x:Name="Ch4Settings" Grid.Row="1" Grid.Column="4" Margin="4,0,0,0" />
            </Grid>

            <Border x:Name="SmartMixSection" Style="{StaticResource CardPanel}" Margin="0,10,0,0">
                <StackPanel>
                    <Border x:Name="SmartMixHeader" Cursor="Hand"
                            Background="Transparent" Padding="0,0,0,0"
                            MouseLeftButtonDown="SmartMixHeader_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                            <TextBlock Text="SMART MIX" Style="{StaticResource HeaderText}" Margin="0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="SmartMixArrow" Text="▶" FontSize="9"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>
                    <StackPanel x:Name="SmartMixContent" Visibility="Collapsed" Margin="0,12,0,0" />
                </StackPanel>
            </Border>

            <Border x:Name="AudioSessionsSection" Style="{StaticResource CardPanel}" Margin="0,10,0,0">
                <StackPanel>
                    <Border x:Name="AudioSessionsHeader" Cursor="Hand"
                            Background="Transparent" Padding="0,0,0,0"
                            MouseLeftButtonDown="AudioSessionsHeader_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                            <TextBlock Text="AUDIO SESSIONS" Style="{StaticResource HeaderText}" Margin="0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="AudioSessionsArrow" Text="▶" FontSize="9"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>
                    <StackPanel x:Name="AudioSessionsContent" Visibility="Collapsed" Margin="0,12,0,0" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
