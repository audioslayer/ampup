<UserControl x:Class="AmpUp.Views.AmbienceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top bar: settings link + status -->
            <RowDefinition Height="Auto" />
            <!-- Setup prompt OR device cards -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
            <StackPanel x:Name="TopBar" />
        </Border>

        <!-- Main content area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="DevicePanel" Margin="0,0,0,24" />
        </ScrollViewer>
    </Grid>
</UserControl>
