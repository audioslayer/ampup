<UserControl x:Class="AmpUp.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel Margin="24,16,24,24">

            <!-- ── CONNECTION ──────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="CONNECTION" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>

                    <!-- Status indicator -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
                        <Ellipse x:Name="ConnectionDot" Width="8" Height="8"
                                 Fill="#FF4444" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="TxtConnectionStatus"
                                   Text="Disconnected"
                                   Style="{StaticResource SecondaryText}"
                                   VerticalAlignment="Center" Margin="0" />
                    </StackPanel>

                    <!-- Port selector row -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Device Port" Style="{StaticResource SecondaryText}" Margin="0,0,0,6"
                                   ToolTip="Select the COM port for your Turn Up hardware" />
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="CmbSerialPort" Width="220" Height="32"
                                      Background="{StaticResource InputBgBrush}"
                                      BorderBrush="{StaticResource InputBorderBrush}"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      ToolTip="Available COM ports — select the one for your Turn Up device" />
                            <ui:Button x:Name="BtnRefreshPorts" Content="Refresh"
                                       Appearance="Secondary" Margin="8,0,0,0" Height="32"
                                       ToolTip="Rescan for available COM ports" />
                            <ui:Button x:Name="BtnAutoDetect" Content="Auto-Detect"
                                       Appearance="Primary" Margin="8,0,0,0" Height="32"
                                       ToolTip="Automatically find the Turn Up device by probing available ports" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Advanced toggle -->
                    <Border BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0"
                            Margin="0,4,0,0" Padding="0,10,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Cursor="Hand" Margin="0,0,0,0"
                                        x:Name="AdvancedToggle" MouseLeftButtonDown="AdvancedToggle_Click">
                                <TextBlock x:Name="AdvancedArrow" Text="▶" FontSize="9"
                                           Foreground="{StaticResource TextDimBrush}"
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Advanced" Style="{StaticResource SecondaryText}"
                                           VerticalAlignment="Center" Margin="0" />
                            </StackPanel>

                            <StackPanel x:Name="AdvancedSection" Visibility="Collapsed" Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="Serial Port" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"
                                                   ToolTip="COM port for the Turn Up hardware (e.g. COM3)" />
                                        <ui:TextBox x:Name="TxtSerialPort" Width="160"
                                                    PlaceholderText="COM3"
                                                    Background="{StaticResource InputBgBrush}"
                                                    BorderBrush="{StaticResource InputBorderBrush}"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    ToolTip="COM port for the Turn Up hardware (e.g. COM3)" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Baud Rate" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"
                                                   ToolTip="Communication speed — leave at 115200" />
                                        <ui:TextBox x:Name="TxtBaudRate" Width="160"
                                                    PlaceholderText="115200"
                                                    Background="{StaticResource InputBgBrush}"
                                                    BorderBrush="{StaticResource InputBorderBrush}"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    ToolTip="Communication speed — leave at 115200" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ── STARTUP ─────────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="STARTUP" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>
                    <CheckBox x:Name="ChkStartWithWindows"
                              Content="Start with Windows"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              VerticalContentAlignment="Center"
                              ToolTip="Launch Amp Up automatically when you log in" />

                </StackPanel>
            </Border>

            <!-- ── APPEARANCE ────────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="APPEARANCE" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>
                    <TextBlock Text="Accent Color" Style="{StaticResource SecondaryText}" Margin="0,0,0,8"
                               ToolTip="App-wide theme color — affects headers, LEDs, and highlights" />
                    <WrapPanel x:Name="AccentSwatches" Orientation="Horizontal" />
                </StackPanel>
            </Border>

            <!-- ── PREFERENCES ───────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="PREFERENCES" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>
                    <CheckBox x:Name="ChkAutoSuggestLayout"
                              Content="Auto-suggest knob layout"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              VerticalContentAlignment="Center"
                              ToolTip="Show a banner in Mixer when known apps are detected and knobs are unassigned" />
                </StackPanel>
            </Border>

            <!-- ── OSD OVERLAY ────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="OSD OVERLAY" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>
                    <TextBlock Text="Show overlay notifications when the app is minimized to tray."
                               Style="{StaticResource SecondaryText}" Margin="0,0,0,12" />

                    <!-- Toggles -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <CheckBox x:Name="ChkOsdVolume"
                                  Content="Volume changes"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="0,0,24,0"
                                  ToolTip="Show overlay when you adjust a knob" />
                        <CheckBox x:Name="ChkOsdProfile"
                                  Content="Profile switches"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="0,0,24,0"
                                  ToolTip="Show overlay when switching profiles" />
                        <CheckBox x:Name="ChkOsdDevice"
                                  Content="Device switches"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  ToolTip="Show overlay when cycling audio devices" />
                    </StackPanel>

                    <!-- Position picker -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Position" Style="{StaticResource SecondaryText}" Margin="0,0,0,6" />

                            <!-- Fraps-style screen position picker -->
                            <Border Background="{StaticResource InputBgBrush}"
                                    BorderBrush="{StaticResource InputBorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Width="160" Height="100" Padding="6">
                                <Grid x:Name="OsdPositionGrid">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 6 position buttons (Fraps-style corners + centers) -->
                                    <Border x:Name="PosTopLeft" Grid.Row="0" Grid.Column="0"
                                            Style="{StaticResource CardPanel}" Margin="2" Padding="0"
                                            CornerRadius="4" Cursor="Hand"
                                            MouseLeftButtonDown="OsdPosition_Click" Tag="TopLeft">
                                        <TextBlock Text="TL" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border x:Name="PosTopCenter" Grid.Row="0" Grid.Column="1"
                                            Style="{StaticResource CardPanel}" Margin="2" Padding="0"
                                            CornerRadius="4" Cursor="Hand"
                                            MouseLeftButtonDown="OsdPosition_Click" Tag="TopCenter">
                                        <TextBlock Text="TC" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border x:Name="PosTopRight" Grid.Row="0" Grid.Column="2"
                                            Style="{StaticResource CardPanel}" Margin="2" Padding="0"
                                            CornerRadius="4" Cursor="Hand"
                                            MouseLeftButtonDown="OsdPosition_Click" Tag="TopRight">
                                        <TextBlock Text="TR" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border x:Name="PosBottomLeft" Grid.Row="1" Grid.Column="0"
                                            Style="{StaticResource CardPanel}" Margin="2" Padding="0"
                                            CornerRadius="4" Cursor="Hand"
                                            MouseLeftButtonDown="OsdPosition_Click" Tag="BottomLeft">
                                        <TextBlock Text="BL" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border x:Name="PosBottomCenter" Grid.Row="1" Grid.Column="1"
                                            Style="{StaticResource CardPanel}" Margin="2" Padding="0"
                                            CornerRadius="4" Cursor="Hand"
                                            MouseLeftButtonDown="OsdPosition_Click" Tag="BottomCenter">
                                        <TextBlock Text="BC" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border x:Name="PosBottomRight" Grid.Row="1" Grid.Column="2"
                                            Style="{StaticResource CardPanel}" Margin="2" Padding="0"
                                            CornerRadius="4" Cursor="Hand"
                                            MouseLeftButtonDown="OsdPosition_Click" Tag="BottomRight">
                                        <TextBlock Text="BR" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <ui:Button x:Name="BtnOsdPreview" Content="Preview"
                                   Appearance="Secondary" VerticalAlignment="Bottom" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── PROFILES ────────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="PROFILES" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Active Profile" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"
                                       ToolTip="The currently loaded profile" />
                            <ComboBox x:Name="CmbProfiles" Width="200"
                                      Background="{StaticResource InputBgBrush}"
                                      BorderBrush="{StaticResource InputBorderBrush}"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      ToolTip="Select a profile to load or manage" />
                        </StackPanel>
                        <StackPanel VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal">
                                <ui:Button x:Name="BtnSaveProfile" Content="Save"
                                           Appearance="Primary" Margin="0,0,6,0"
                                           ToolTip="Save current settings to this profile" />
                                <ui:Button x:Name="BtnLoadProfile" Content="Load"
                                           Appearance="Secondary" Margin="0,0,6,0"
                                           ToolTip="Load the selected profile" />
                                <ui:Button x:Name="BtnNewProfile" Content="New"
                                           Appearance="Secondary" Margin="0,0,6,0"
                                           ToolTip="Create a new profile from current settings" />
                                <ui:Button x:Name="BtnDeleteProfile" Content="Delete"
                                           Appearance="Danger"
                                           ToolTip="Delete the selected profile (cannot be undone)" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Export / Import profile files -->
                    <Border BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0"
                            Margin="0,14,0,0" Padding="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Export or import profile files to share between machines."
                                       Style="{StaticResource SecondaryText}" Margin="0,0,0,8" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal">
                                <ui:Button x:Name="BtnExportProfile" Content="Export Profile"
                                           Appearance="Secondary" Margin="0,0,8,0"
                                           ToolTip="Save the current profile as a .json file" />
                                <ui:Button x:Name="BtnImportProfile" Content="Import Profile"
                                           Appearance="Secondary"
                                           ToolTip="Load a profile from a .json file" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Import from Turn Up -->
                    <Border BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0"
                            Margin="0,14,0,0" Padding="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Have an existing Turn Up configuration? Import your knob, button, and light settings."
                                       Style="{StaticResource SecondaryText}" Margin="0,0,0,8" TextWrapping="Wrap" />
                            <ui:Button x:Name="BtnImportTurnUp" Content="Import from Turn Up"
                                       Appearance="Secondary" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── INTEGRATIONS ────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="INTEGRATIONS" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>

                    <!-- Home Assistant -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Home Assistant" Style="{StaticResource BodyText}" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <CheckBox x:Name="ChkHaEnabled"
                                  Content="Enabled"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="URL" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                                <ui:TextBox x:Name="TxtHaUrl" Width="320"
                                            PlaceholderText="http://homeassistant.local:8123"
                                            Background="{StaticResource InputBgBrush}"
                                            BorderBrush="{StaticResource InputBorderBrush}"
                                            Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Token" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                                <PasswordBox x:Name="TxtHaToken" Width="320"
                                             Background="{StaticResource InputBgBrush}"
                                             BorderBrush="{StaticResource InputBorderBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ── ABOUT ─────────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="ABOUT" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtVersion" Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                        <ui:Button x:Name="BtnCheckUpdate" Content="Check for Updates"
                                   Appearance="Secondary" Margin="16,0,0,0" />
                    </StackPanel>
                    <TextBlock x:Name="TxtUpdateStatus" Style="{StaticResource SecondaryText}" Margin="0,8,0,0"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
