<UserControl x:Class="WolfMixer.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel Margin="24,16,24,24">

            <!-- ── CONNECTION ──────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="CONNECTION" Style="{StaticResource HeaderText}" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="Serial Port" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                            <ui:TextBox x:Name="TxtSerialPort" Width="160"
                                        PlaceholderText="COM3"
                                        Background="{StaticResource InputBgBrush}"
                                        BorderBrush="{StaticResource InputBorderBrush}"
                                        Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Baud Rate" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                            <ui:TextBox x:Name="TxtBaudRate" Width="160"
                                        PlaceholderText="115200"
                                        Background="{StaticResource InputBgBrush}"
                                        BorderBrush="{StaticResource InputBorderBrush}"
                                        Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── STARTUP ─────────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="STARTUP" Style="{StaticResource HeaderText}" Margin="0,0,0,12" />
                    <CheckBox x:Name="ChkStartWithWindows"
                              Content="Start with Windows"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              VerticalContentAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- ── PROFILES ────────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="PROFILES" Style="{StaticResource HeaderText}" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Active Profile" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                            <ComboBox x:Name="CmbProfiles" Width="200"
                                      Background="{StaticResource InputBgBrush}"
                                      BorderBrush="{StaticResource InputBorderBrush}"
                                      Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal">
                                <ui:Button x:Name="BtnSaveProfile" Content="Save"
                                           Appearance="Primary" Margin="0,0,6,0" />
                                <ui:Button x:Name="BtnLoadProfile" Content="Load"
                                           Appearance="Secondary" Margin="0,0,6,0" />
                                <ui:Button x:Name="BtnNewProfile" Content="New"
                                           Appearance="Secondary" Margin="0,0,6,0" />
                                <ui:Button x:Name="BtnDeleteProfile" Content="Delete"
                                           Appearance="Danger" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── INTEGRATIONS ────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="INTEGRATIONS" Style="{StaticResource HeaderText}" Margin="0,0,0,16" />

                    <!-- Home Assistant -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Home Assistant" Style="{StaticResource BodyText}" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <CheckBox x:Name="ChkHaEnabled"
                                  Content="Enabled"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="URL" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                                <ui:TextBox x:Name="TxtHaUrl" Width="320"
                                            PlaceholderText="http://homeassistant.local:8123"
                                            Background="{StaticResource InputBgBrush}"
                                            BorderBrush="{StaticResource InputBorderBrush}"
                                            Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Token" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                                <PasswordBox x:Name="TxtHaToken" Width="320"
                                             Background="{StaticResource InputBgBrush}"
                                             BorderBrush="{StaticResource InputBorderBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Separator -->
                    <Border Height="1" Background="{StaticResource CardBorderBrush}" Margin="0,0,0,16" />

                    <!-- FanControl -->
                    <StackPanel>
                        <TextBlock Text="FanControl" Style="{StaticResource BodyText}" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <CheckBox x:Name="ChkFcEnabled"
                                  Content="Enabled"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="0,0,0,8" />
                        <StackPanel>
                            <TextBlock Text="URL" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                            <ui:TextBox x:Name="TxtFcUrl" Width="320"
                                        PlaceholderText="http://localhost:5550"
                                        Background="{StaticResource InputBgBrush}"
                                        BorderBrush="{StaticResource InputBorderBrush}"
                                        Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
