<UserControl x:Class="AmpUp.Views.HomeAssistantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Connection status card -->
            <RowDefinition Height="Auto" />
            <!-- 5 channel columns -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Connection Status Card -->
        <Border x:Name="ConnCard" Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
            <Grid x:Name="ConnContent" />
        </Border>

        <!-- 5 Channel Columns -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid x:Name="ColumnsGrid" Grid.IsSharedSizeScope="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,4,0">
                    <Grid x:Name="Ch0Grid" />
                </Border>
                <Border Grid.Column="1" Style="{StaticResource CardPanel}" Margin="4,0">
                    <Grid x:Name="Ch1Grid" />
                </Border>
                <Border Grid.Column="2" Style="{StaticResource CardPanel}" Margin="4,0">
                    <Grid x:Name="Ch2Grid" />
                </Border>
                <Border Grid.Column="3" Style="{StaticResource CardPanel}" Margin="4,0">
                    <Grid x:Name="Ch3Grid" />
                </Border>
                <Border Grid.Column="4" Style="{StaticResource CardPanel}" Margin="4,0,0,0">
                    <Grid x:Name="Ch4Grid" />
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
