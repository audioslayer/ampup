<UserControl x:Class="AmpUp.Views.OsdView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:AmpUp.Controls">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel Margin="24,16,24,24">

            <!-- ── OSD OVERLAY ────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="OSD OVERLAY" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>
                    <TextBlock Text="Show overlay notifications when the app is minimized to tray."
                               Style="{StaticResource SecondaryText}" Margin="0,0,0,14" />

                    <!-- Notification type rows — checkbox + duration slider each -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <CheckBox x:Name="ChkOsdVolume" Grid.Row="0" Grid.Column="0"
                                  Content="Volume Changes" Margin="0,6,0,6"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  ToolTip="Show overlay when you adjust a knob" />
                        <controls:StyledSlider x:Name="SldOsdVolumeDur" Grid.Row="0" Grid.Column="1"
                                Minimum="0.3" Maximum="8" Value="2" ShowLabel="False"
                                Height="24" Margin="0,6,8,6"
                                ToolTip="How long the volume overlay stays visible" />
                        <TextBlock x:Name="LblOsdVolumeDur" Grid.Row="0" Grid.Column="2"
                                   Text="2.0s" Foreground="{StaticResource TextSecBrush}"
                                   FontSize="12" VerticalAlignment="Center" />

                        <CheckBox x:Name="ChkOsdProfile" Grid.Row="1" Grid.Column="0"
                                  Content="Profile Changes" Margin="0,6,0,6"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  ToolTip="Show overlay when switching profiles" />
                        <controls:StyledSlider x:Name="SldOsdProfileDur" Grid.Row="1" Grid.Column="1"
                                Minimum="0.3" Maximum="8" Value="3.5" ShowLabel="False"
                                Height="24" Margin="0,6,8,6"
                                ToolTip="How long the profile overlay stays visible" />
                        <TextBlock x:Name="LblOsdProfileDur" Grid.Row="1" Grid.Column="2"
                                   Text="3.5s" Foreground="{StaticResource TextSecBrush}"
                                   FontSize="12" VerticalAlignment="Center" />

                        <CheckBox x:Name="ChkOsdDevice" Grid.Row="2" Grid.Column="0"
                                  Content="Device Changes" Margin="0,6,0,6"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  ToolTip="Show overlay when cycling audio devices" />
                        <controls:StyledSlider x:Name="SldOsdDeviceDur" Grid.Row="2" Grid.Column="1"
                                Minimum="0.3" Maximum="8" Value="2.5" ShowLabel="False"
                                Height="24" Margin="0,6,8,6"
                                ToolTip="How long the device overlay stays visible" />
                        <TextBlock x:Name="LblOsdDeviceDur" Grid.Row="2" Grid.Column="2"
                                   Text="2.5s" Foreground="{StaticResource TextSecBrush}"
                                   FontSize="12" VerticalAlignment="Center" />

                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Text="Quick Wheel" Margin="4,6,0,6"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13" VerticalAlignment="Center" />
                        <controls:StyledSlider x:Name="SldOsdWheelDur" Grid.Row="3" Grid.Column="1"
                                Minimum="1" Maximum="15" Value="5" ShowLabel="False"
                                Height="24" Margin="0,6,8,6"
                                ToolTip="How long the Quick Wheel stays visible after releasing the button" />
                        <TextBlock x:Name="LblOsdWheelDur" Grid.Row="3" Grid.Column="2"
                                   Text="5.0s" Foreground="{StaticResource TextSecBrush}"
                                   FontSize="12" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="{StaticResource CardBorderBrush}" Margin="0,10,0,12" />

                    <!-- Position + Monitor row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Position picker -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Position" Style="{StaticResource SecondaryText}" Margin="0,0,0,6" />
                            <Border Background="{StaticResource InputBgBrush}"
                                    BorderBrush="{StaticResource InputBorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Width="160" Height="100" Padding="6">
                                <Grid x:Name="OsdPositionGrid">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="PosTopLeft" Grid.Row="0" Grid.Column="0"
                                            Style="{StaticResource CardPanel}" Margin="2" Padding="0"
                                            CornerRadius="4" Cursor="Hand"
                                            MouseLeftButtonDown="OsdPosition_Click" Tag="TopLeft">
                                        <TextBlock Text="TL" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border x:Name="PosTopCenter" Grid.Row="0" Grid.Column="1"
                                            Style="{StaticResource CardPanel}" Margin="2" Padding="0"
                                            CornerRadius="4" Cursor="Hand"
                                            MouseLeftButtonDown="OsdPosition_Click" Tag="TopCenter">
                                        <TextBlock Text="TC" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border x:Name="PosTopRight" Grid.Row="0" Grid.Column="2"
                                            Style="{StaticResource CardPanel}" Margin="2" Padding="0"
                                            CornerRadius="4" Cursor="Hand"
                                            MouseLeftButtonDown="OsdPosition_Click" Tag="TopRight">
                                        <TextBlock Text="TR" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border x:Name="PosBottomLeft" Grid.Row="1" Grid.Column="0"
                                            Style="{StaticResource CardPanel}" Margin="2" Padding="0"
                                            CornerRadius="4" Cursor="Hand"
                                            MouseLeftButtonDown="OsdPosition_Click" Tag="BottomLeft">
                                        <TextBlock Text="BL" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border x:Name="PosBottomCenter" Grid.Row="1" Grid.Column="1"
                                            Style="{StaticResource CardPanel}" Margin="2" Padding="0"
                                            CornerRadius="4" Cursor="Hand"
                                            MouseLeftButtonDown="OsdPosition_Click" Tag="BottomCenter">
                                        <TextBlock Text="BC" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border x:Name="PosBottomRight" Grid.Row="1" Grid.Column="2"
                                            Style="{StaticResource CardPanel}" Margin="2" Padding="0"
                                            CornerRadius="4" Cursor="Hand"
                                            MouseLeftButtonDown="OsdPosition_Click" Tag="BottomRight">
                                        <TextBlock Text="BR" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Monitor + Preview + Fullscreen -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Top">
                            <TextBlock Text="Monitor" Style="{StaticResource SecondaryText}" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal">
                                <ComboBox x:Name="CmbOsdMonitor" Width="280"
                                          SelectionChanged="CmbOsdMonitor_SelectionChanged"
                                          ToolTip="Which monitor to show the OSD on" />
                                <ui:Button x:Name="BtnOsdPreview" Content="Preview"
                                           Appearance="Secondary" Margin="12,0,0,0" />
                            </StackPanel>

                            <CheckBox x:Name="ChkHideInFullscreen"
                                      Content="Hide OSD over fullscreen apps and games"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      Margin="0,14,0,0"
                                      ToolTip="When checked, OSD won't appear over fullscreen games or apps" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── QUICK WHEELS ───────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="QUICK WHEELS" Style="{StaticResource HeaderText}" Margin="0" />
                    </StackPanel>
                    <TextBlock Text="Hold a button to open a radial overlay. Turn any knob to navigate. Release to confirm. Add multiple wheels for different buttons."
                               Style="{StaticResource SecondaryText}" Margin="0,0,0,12" TextWrapping="Wrap" />

                    <!-- Dynamic wheel rows built in code-behind -->
                    <StackPanel x:Name="WheelRowsPanel" />

                    <ui:Button x:Name="BtnAddWheel" Content="+ Add Quick Wheel"
                               Appearance="Secondary" Margin="0,8,0,0"
                               ToolTip="Add another Quick Wheel binding" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
