<UserControl x:Class="AmpUp.Views.LightsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <!-- Global Lighting Card (includes presets) -->
            <Border x:Name="GlobalLightCard" Background="Transparent" BorderThickness="0" Margin="0,0,0,8" Padding="0">
                <StackPanel>
                    <!-- Global lighting controls built in code-behind -->
                    <StackPanel x:Name="GlobalLightCardPanel" />
                    <!-- Presets built in code-behind (shown when global enabled) -->
                    <StackPanel x:Name="PresetsPanel" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- Hidden — kept for code-behind references -->
            <Border x:Name="PresetsCard" Visibility="Collapsed" />

            <!-- Per-knob editor: selector row + single editor container -->
            <StackPanel x:Name="PerKnobGrid">
                <!-- Knob selector row (5 compact cards, built in code-behind) -->
                <StackPanel x:Name="KnobSelectorRow"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,10" />

                <!-- Single editor container — holds all 5 LED panels as siblings,
                     only the selected knob's panel is visible at a time.
                     Each section wraps itself in its own card in code-behind. -->
                <Grid x:Name="PerKnobEditor">
                    <StackPanel x:Name="Led0Panel" />
                    <StackPanel x:Name="Led1Panel" Visibility="Collapsed" />
                    <StackPanel x:Name="Led2Panel" Visibility="Collapsed" />
                    <StackPanel x:Name="Led3Panel" Visibility="Collapsed" />
                    <StackPanel x:Name="Led4Panel" Visibility="Collapsed" />
                </Grid>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
