<UserControl x:Class="AmpUp.Views.LightsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <!-- Global Lighting card -->
            <RowDefinition Height="Auto" />
            <!-- LED cards -->
            <RowDefinition Height="*" />
            <!-- Global brightness -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Global Lighting Card (built in code-behind via BuildGlobalCard) -->
        <Border x:Name="GlobalLightCard" Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
            <StackPanel x:Name="GlobalLightCardPanel" />
        </Border>

        <!-- 5 LED Channel Cards -->
        <Grid x:Name="PerKnobGrid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LED 1 -->
            <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,4,0">
                <StackPanel x:Name="Led0Panel" />
            </Border>

            <!-- LED 2 -->
            <Border Grid.Column="1" Style="{StaticResource CardPanel}" Margin="4,0">
                <StackPanel x:Name="Led1Panel" />
            </Border>

            <!-- LED 3 -->
            <Border Grid.Column="2" Style="{StaticResource CardPanel}" Margin="4,0">
                <StackPanel x:Name="Led2Panel" />
            </Border>

            <!-- LED 4 -->
            <Border Grid.Column="3" Style="{StaticResource CardPanel}" Margin="4,0">
                <StackPanel x:Name="Led3Panel" />
            </Border>

            <!-- LED 5 -->
            <Border Grid.Column="4" Style="{StaticResource CardPanel}" Margin="4,0,0,0">
                <StackPanel x:Name="Led4Panel" />
            </Border>
        </Grid>

        <!-- Global Brightness -->
        <Border Grid.Row="2" Style="{StaticResource CardPanel}" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="GLOBAL BRIGHTNESS"
                           Style="{StaticResource SecondaryText}"
                           FontWeight="SemiBold" VerticalAlignment="Center"
                           Margin="0,0,16,0" />
                <Slider x:Name="BrightnessSlider" Grid.Column="1"
                        Minimum="0" Maximum="100" Value="100"
                        VerticalAlignment="Center"
                        IsSnapToTickEnabled="True" TickFrequency="1" />
                <TextBlock x:Name="BrightnessValueLabel" Grid.Column="2"
                           Style="{StaticResource BodyText}"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           Text="100%" MinWidth="36" TextAlignment="Right" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
