<UserControl x:Class="AmpUp.Views.LightsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <!-- Presets Section (built in code-behind via BuildPresetsSection) -->
            <Border x:Name="PresetsCard" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel x:Name="PresetsPanel" />
            </Border>

            <!-- Global Lighting Card (built in code-behind via BuildGlobalCard) -->
            <Border x:Name="GlobalLightCard" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel x:Name="GlobalLightCardPanel" />
            </Border>

            <!-- 5 LED Channel Cards -->
            <Grid x:Name="PerKnobGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- LED 1 -->
                <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,4,0">
                    <StackPanel x:Name="Led0Panel" />
                </Border>

                <!-- LED 2 -->
                <Border Grid.Column="1" Style="{StaticResource CardPanel}" Margin="4,0">
                    <StackPanel x:Name="Led1Panel" />
                </Border>

                <!-- LED 3 -->
                <Border Grid.Column="2" Style="{StaticResource CardPanel}" Margin="4,0">
                    <StackPanel x:Name="Led2Panel" />
                </Border>

                <!-- LED 4 -->
                <Border Grid.Column="3" Style="{StaticResource CardPanel}" Margin="4,0">
                    <StackPanel x:Name="Led3Panel" />
                </Border>

                <!-- LED 5 -->
                <Border Grid.Column="4" Style="{StaticResource CardPanel}" Margin="4,0,0,0">
                    <StackPanel x:Name="Led4Panel" />
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
