<UserControl x:Class="AmpUp.Views.LightsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <!-- Global Lighting Card (includes presets) -->
            <Border x:Name="GlobalLightCard" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel>
                    <!-- Global lighting controls built in code-behind -->
                    <StackPanel x:Name="GlobalLightCardPanel" />
                    <!-- Presets built in code-behind (shown when global enabled) -->
                    <StackPanel x:Name="PresetsPanel" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- Hidden — kept for code-behind references -->
            <Border x:Name="PresetsCard" Visibility="Collapsed" />

            <!-- Knob Selector Row -->
            <Border x:Name="KnobSelectorCard" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <WrapPanel x:Name="KnobSelectorPanel" HorizontalAlignment="Center" Margin="8,12" />
            </Border>

            <!-- Selected Knob Settings Panel -->
            <Border x:Name="PerKnobCard" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel x:Name="PerKnobSettingsPanel" Margin="12" />
            </Border>

            <!-- Legacy grid kept collapsed for any remaining code references -->
            <Grid x:Name="PerKnobGrid" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,4,0"><StackPanel x:Name="Led0Panel" /></Border>
                <Border Grid.Column="1" Style="{StaticResource CardPanel}" Margin="4,0"><StackPanel x:Name="Led1Panel" /></Border>
                <Border Grid.Column="2" Style="{StaticResource CardPanel}" Margin="4,0"><StackPanel x:Name="Led2Panel" /></Border>
                <Border Grid.Column="3" Style="{StaticResource CardPanel}" Margin="4,0"><StackPanel x:Name="Led3Panel" /></Border>
                <Border Grid.Column="4" Style="{StaticResource CardPanel}" Margin="4,0,0,0"><StackPanel x:Name="Led4Panel" /></Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
