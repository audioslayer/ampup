<UserControl x:Class="AmpUp.Views.ButtonsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid x:Name="ColumnsGrid" Grid.IsSharedSizeScope="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,4,0" VerticalAlignment="Top">
                <Grid x:Name="Btn0Grid" />
            </Border>
            <Border Grid.Column="1" Style="{StaticResource CardPanel}" Margin="4,0" VerticalAlignment="Top">
                <Grid x:Name="Btn1Grid" />
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardPanel}" Margin="4,0" VerticalAlignment="Top">
                <Grid x:Name="Btn2Grid" />
            </Border>
            <Border Grid.Column="3" Style="{StaticResource CardPanel}" Margin="4,0" VerticalAlignment="Top">
                <Grid x:Name="Btn3Grid" />
            </Border>
            <Border Grid.Column="4" Style="{StaticResource CardPanel}" Margin="4,0,0,0" VerticalAlignment="Top">
                <Grid x:Name="Btn4Grid" />
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
