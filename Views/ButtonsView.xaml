<UserControl x:Class="WolfMixer.Views.ButtonsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <!-- Button selector strip -->
            <RowDefinition Height="Auto" />
            <!-- Detail config area -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top: 5 button tiles -->
        <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,12" Padding="12">
            <StackPanel>
                <TextBlock Text="SELECT BUTTON" Style="{StaticResource SecondaryText}"
                           FontWeight="SemiBold" FontSize="10" Margin="0,0,0,10" />
                <UniformGrid x:Name="ButtonStrip" Rows="1" Columns="5" />
            </StackPanel>
        </Border>

        <!-- Bottom: Config detail for selected button -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="DetailPanel" />
        </ScrollViewer>
    </Grid>
</UserControl>
