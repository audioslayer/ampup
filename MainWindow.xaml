<ui:FluentWindow x:Class="WolfMixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:views="clr-namespace:WolfMixer.Views"
        Title="Amp Up"
        Width="1400" Height="900"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ConnectionDot"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.4" Duration="0:0:1"
                             AutoReverse="True" />
        </Storyboard>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Title bar area -->
            <RowDefinition Height="48" />
            <!-- Content -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header Bar (draggable) -->
        <Grid Grid.Row="0" Background="{StaticResource BgBaseBrush}"
              MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Branding -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                <Image Source="pack://application:,,,/Assets/ampuplogo.png" Height="38"
                       RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center" />
                <TextBlock VerticalAlignment="Center" Margin="6,0,0,0">
                    <Run Text="AMP" FontFamily="Segoe UI Black" FontSize="16" FontWeight="Black"
                         Foreground="#2E8B38" />
                    <Run Text=" " FontSize="4" />
                    <Run Text="UP" FontFamily="Segoe UI Black" FontSize="16" FontWeight="Black"
                         Foreground="#4CAF50" />
                </TextBlock>
            </StackPanel>

            <!-- Connection Status + Window Controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                <Ellipse x:Name="ConnectionDot" Width="8" Height="8" Fill="{StaticResource TextDimBrush}" Margin="0,0,8,0" />
                <TextBlock x:Name="ConnectionLabel" Text="Disconnected" Style="{StaticResource SecondaryText}" VerticalAlignment="Center" />
                <TextBlock x:Name="VersionLabel" Text="v0.1-alpha" Foreground="{StaticResource TextDimBrush}" FontSize="10"
                           VerticalAlignment="Center" Margin="10,0,0,0" Cursor="Hand"
                           MouseLeftButtonDown="VersionLabel_Click"
                           ToolTip="Click to check for updates" />

                <!-- Mac-style traffic light buttons -->
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                    <!-- Minimize (yellow) -->
                    <Border x:Name="BtnMinimize" Width="14" Height="14" CornerRadius="7"
                            Background="#FFBD2E" Margin="0,0,8,0" Cursor="Hand"
                            MouseLeftButtonDown="BtnMinimize_Click"
                            ToolTip="Minimize">
                        <TextBlock Text="—" FontSize="8" FontWeight="Bold" Foreground="#995700"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="0,-2,0,0" Opacity="0" x:Name="MinIcon" />
                    </Border>
                    <!-- Maximize (green) -->
                    <Border x:Name="BtnMaximize" Width="14" Height="14" CornerRadius="7"
                            Background="#27C93F" Margin="0,0,8,0" Cursor="Hand"
                            MouseLeftButtonDown="BtnMaximize_Click"
                            ToolTip="Maximize">
                        <TextBlock Text="⤢" FontSize="9" FontWeight="Bold" Foreground="#0A6C15"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="0,-1,0,0" Opacity="0" x:Name="MaxIcon" />
                    </Border>
                    <!-- Close (red) -->
                    <Border x:Name="BtnClose" Width="14" Height="14" CornerRadius="7"
                            Background="#FF5F56" Cursor="Hand"
                            MouseLeftButtonDown="BtnClose_Click"
                            ToolTip="Close">
                        <TextBlock Text="✕" FontSize="8" FontWeight="Bold" Foreground="#990F04"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="0,-1,0,0" Opacity="0" x:Name="CloseIcon" />
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Main Layout: Sidebar + Content -->
        <Grid Grid.Row="1" Background="{StaticResource BgDarkBrush}">
            <Grid.ColumnDefinitions>
                <!-- Sidebar -->
                <ColumnDefinition Width="76" />
                <!-- Content -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar Navigation -->
            <Border Grid.Column="0" Background="{StaticResource BgBaseBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Profile button at top of sidebar -->
                    <Border x:Name="ProfileButton" Grid.Row="0" Width="54" Height="54" CornerRadius="12"
                            Background="{StaticResource CardBgBrush}"
                            BorderThickness="1.5" Margin="11,14,11,4" Cursor="Hand" ToolTip="Switch profile"
                            MouseLeftButtonUp="ProfileButton_Click">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#8800E676" Offset="0" />
                                <GradientStop Color="#4400E676" Offset="1" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect Color="#00E676" BlurRadius="16" Opacity="0.3" ShadowDepth="0" />
                        </Border.Effect>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ui:SymbolIcon x:Name="ProfileIcon" Symbol="Speaker224" FontSize="22"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" />
                            <TextBlock x:Name="ProfileLabel" Text="Default" FontSize="7"
                                       Foreground="{StaticResource TextDimBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis" MaxWidth="48" TextAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Separator line under profile button -->
                    <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1" Margin="16,0,16,0"
                            Background="#2200E676" />

                    <!-- Profile flyout popup -->
                    <Popup x:Name="ProfilePopup" PlacementTarget="{Binding ElementName=ProfileButton}"
                           Placement="Right" StaysOpen="False" AllowsTransparency="True"
                           PopupAnimation="Fade" HorizontalOffset="4">
                        <Border x:Name="ProfilePopupBorder" Background="#FF151515" BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="6" MinWidth="200">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="24" Opacity="0.6" ShadowDepth="6" />
                            </Border.Effect>
                            <StackPanel x:Name="ProfilePopupPanel" />
                        </Border>
                    </Popup>

                    <DockPanel Grid.Row="1" Margin="0,8,0,0" LastChildFill="True">
                        <!-- Import button pinned to bottom -->
                        <Button x:Name="NavImport" Style="{StaticResource NavButton}" Click="NavImport_Click"
                                DockPanel.Dock="Bottom" ToolTip="Import from Turn Up">
                            <StackPanel HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="20" Foreground="#00E676" HorizontalAlignment="Center" />
                                <TextBlock Text="Import" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                           HorizontalAlignment="Center" Margin="0,3,0,0" />
                            </StackPanel>
                        </Button>

                        <!-- Nav items -->
                        <StackPanel>
                            <Button x:Name="NavMixer" Style="{StaticResource NavButton}" Click="NavMixer_Click">
                                <StackPanel HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="MusicNote124" FontSize="20" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="NavMixerLabel" Text="Mixer" FontSize="9" Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center" Margin="0,3,0,0" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavButtons" Style="{StaticResource NavButton}" Click="NavButtons_Click">
                                <StackPanel HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="KeyboardShiftUppercase24" FontSize="20" Foreground="White" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="NavButtonsLabel" Text="Buttons" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                               HorizontalAlignment="Center" Margin="0,3,0,0" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavLights" Style="{StaticResource NavButton}" Click="NavLights_Click">
                                <StackPanel HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="Color24" FontSize="20" Foreground="White" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="NavLightsLabel" Text="Lights" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                               HorizontalAlignment="Center" Margin="0,3,0,0" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavHA" Style="{StaticResource NavButton}" Click="NavHA_Click">
                                <StackPanel HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="Home24" FontSize="20" Foreground="White" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="NavHALabel" Text="HA" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                               HorizontalAlignment="Center" Margin="0,3,0,0" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavSettings" Style="{StaticResource NavButton}" Click="NavSettings_Click">
                                <StackPanel HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="Settings24" FontSize="20" Foreground="White" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="NavSettingsLabel" Text="Settings" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                               HorizontalAlignment="Center" Margin="0,3,0,0" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Border Grid.Column="1" Padding="24,16">
                <ContentControl x:Name="ContentArea" />
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
