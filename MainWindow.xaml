<ui:FluentWindow x:Class="WolfMixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:views="clr-namespace:WolfMixer.Views"
        Title="WolfMixer"
        Width="1000" Height="700"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Title bar area -->
            <RowDefinition Height="48" />
            <!-- Content -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Grid Grid.Row="0" Background="{StaticResource BgBaseBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Branding -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="WOLFMIXER" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Connection Status -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                <Ellipse x:Name="ConnectionDot" Width="8" Height="8" Fill="{StaticResource TextDimBrush}" Margin="0,0,8,0" />
                <TextBlock x:Name="ConnectionLabel" Text="Disconnected" Style="{StaticResource SecondaryText}" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Main Layout: Sidebar + Content -->
        <Grid Grid.Row="1" Background="{StaticResource BgDarkBrush}">
            <Grid.ColumnDefinitions>
                <!-- Sidebar -->
                <ColumnDefinition Width="56" />
                <!-- Content -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar Navigation -->
            <Border Grid.Column="0" Background="{StaticResource BgBaseBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,12,0,0">
                    <Button x:Name="NavMixer" Width="40" Height="40" Margin="8,4"
                            ToolTip="Mixer" Click="NavMixer_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <ui:SymbolIcon Symbol="Speaker224" FontSize="20" Foreground="{StaticResource AccentBrush}" />
                    </Button>
                    <Button x:Name="NavButtons" Width="40" Height="40" Margin="8,4"
                            ToolTip="Buttons" Click="NavButtons_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <ui:SymbolIcon Symbol="Keyboard24" FontSize="20" Foreground="{StaticResource TextSecBrush}" />
                    </Button>
                    <Button x:Name="NavLights" Width="40" Height="40" Margin="8,4"
                            ToolTip="Lights" Click="NavLights_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <ui:SymbolIcon Symbol="LightbulbFilament24" FontSize="20" Foreground="{StaticResource TextSecBrush}" />
                    </Button>
                    <Button x:Name="NavSettings" Width="40" Height="40" Margin="8,4"
                            ToolTip="Settings" Click="NavSettings_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <ui:SymbolIcon Symbol="Settings24" FontSize="20" Foreground="{StaticResource TextSecBrush}" />
                    </Button>
                </StackPanel>
            </Border>

            <!-- Content Area -->
            <Border Grid.Column="1" Padding="24,16">
                <ContentControl x:Name="ContentArea" />
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
