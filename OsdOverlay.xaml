<Window x:Class="AmpUp.OsdOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        SizeToContent="Height"
        Width="340"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Fade in: slide up + opacity -->
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="RootPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ThicknessAnimation Storyboard.TargetName="RootPanel"
                                Storyboard.TargetProperty="Margin"
                                From="0,16,0,0" To="0,0,0,0" Duration="0:0:0.25">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>

        <!-- Fade out: slide down + opacity -->
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetName="RootPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ThicknessAnimation Storyboard.TargetName="RootPanel"
                                Storyboard.TargetProperty="Margin"
                                From="0,0,0,0" To="0,10,0,0" Duration="0:0:0.3">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>

        <!-- Glow pulse on the volume bar -->
        <Storyboard x:Key="BarGlowPulse" RepeatBehavior="1x">
            <DoubleAnimation Storyboard.TargetName="BarGlow"
                             Storyboard.TargetProperty="Effect.(DropShadowEffect.Opacity)"
                             From="0.8" To="0.25" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <!-- Main glass panel -->
    <Border x:Name="RootPanel" Opacity="0"
            CornerRadius="14" Padding="20,16" Margin="0,0,0,0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#DD111111" Offset="0" />
                <GradientStop Color="#CC0A0A0A" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#5500E676" Offset="0" />
                <GradientStop Color="#2200E676" Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.BorderThickness>1.2</Border.BorderThickness>
        <Border.Effect>
            <DropShadowEffect Color="#00E676" BlurRadius="32" Opacity="0.2" ShadowDepth="0" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Row 0: Category label -->
            <TextBlock x:Name="CategoryLabel" Grid.Row="0"
                       Text="VOLUME"
                       FontFamily="Segoe UI" FontSize="10" FontWeight="Bold"
                       Foreground="#6600E676"
                       Margin="0,0,0,8" />

            <!-- Row 1: Icon + Title + Value -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Icon area (TextBlock for volume/device, SymbolIcon for profile) -->
                <ContentControl x:Name="OsdIconHost" Grid.Column="0"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0" />

                <!-- Title -->
                <TextBlock x:Name="OsdTitle" Grid.Column="1"
                           Text="Master"
                           FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold"
                           Foreground="#E8E8E8"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <!-- Value text -->
                <TextBlock x:Name="OsdValue" Grid.Column="2"
                           Text="75%"
                           FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"
                           Foreground="#00E676"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </Grid>

            <!-- Row 2: Volume bar (hidden for non-volume events) -->
            <Grid x:Name="BarContainer" Grid.Row="2" Height="6" Margin="0,0,0,2">
                <!-- Track background -->
                <Border x:Name="BarTrack" CornerRadius="3"
                        Background="#1A00E676" />

                <!-- Filled portion -->
                <Border x:Name="BarFill" CornerRadius="3"
                        HorizontalAlignment="Left" Width="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00A854" Offset="0" />
                            <GradientStop Color="#00E676" Offset="0.7" />
                            <GradientStop Color="#69F0AE" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Glow on fill -->
                <Border x:Name="BarGlow" CornerRadius="3"
                        HorizontalAlignment="Left" Width="0"
                        IsHitTestVisible="False">
                    <Border.Effect>
                        <DropShadowEffect Color="#00E676" BlurRadius="12" Opacity="0.4" ShadowDepth="0" />
                    </Border.Effect>
                    <Border.Background>
                        <SolidColorBrush Color="#00E676" Opacity="0.4" />
                    </Border.Background>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
