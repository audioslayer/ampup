<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="AmpUp.Mac.Views.AmbienceView">

    <Grid RowDefinitions="Auto,*">

        <!-- Top bar -->
        <Border Grid.Row="0" Classes="CardPanel" Margin="0,0,0,12">
            <StackPanel x:Name="TopBar" Orientation="Horizontal" Spacing="16">
                <StackPanel x:Name="TxtSettingsLink" Orientation="Horizontal" Spacing="4"
                            Cursor="Hand" VerticalAlignment="Center">
                    <mi:MaterialIcon Kind="Cog" Width="14" Height="14"
                                     Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock Text="Settings" FontSize="12"
                               Foreground="{DynamicResource AccentBrush}" />
                </StackPanel>
                <Ellipse x:Name="StatusDot" Width="8" Height="8"
                         Fill="#555555" VerticalAlignment="Center" />
                <TextBlock x:Name="TxtStatus" Text="Govee disabled"
                           Classes="SecondaryText" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="DevicePanel" Margin="0,0,0,24" />
        </ScrollViewer>
    </Grid>
</UserControl>
