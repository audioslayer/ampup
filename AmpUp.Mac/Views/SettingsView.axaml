<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AmpUp.Mac.Views.SettingsView">
    <Border Classes="CardPanel" Margin="0" VerticalAlignment="Top">
        <StackPanel Spacing="8">
            <TextBlock Classes="HeaderText" Text="Settings View" />
            <TextBlock Classes="SecondaryText" Text="Coming Soon — This view will be ported from the Windows version." />
        </StackPanel>
    </Border>
</UserControl>
