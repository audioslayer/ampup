{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "WolfMixer (Debug)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/bin/Debug/net8.0-windows/WolfMixer.exe",
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "stopAtEntry": false
    },
    {
      "name": "WolfMixer (Attach)",
      "type": "coreclr",
      "request": "attach",
      "processName": "WolfMixer"
    }
  ]
}
